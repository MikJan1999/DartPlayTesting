{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "ignoreDeprecations": "6.0",
    

    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx",

    "types": ["node", "@testing-library/jest-dom", "vitest/globals"],

    "baseUrl": "src",
    "paths": {
      "AppSetting": ["AppSetting.js"],
      "hooks/*": ["hooks/*"],
      "components/*": ["components/*"],
      "pages/*": ["pages/*"],
      "services/*": ["services/*"],
      "context/*": ["context/*"]
    },

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true
  },

  "include": [
    "src",
    "tests",
    "playwright.config.ts"
  ],

  "exclude": [
    "node_modules",
    "build",
    "dist"
  ]
}
